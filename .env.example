# ═══════════════════════════════════════════════════════════════════════════
# TrackOra — Environment Variables
# Copy this file to .env and fill in STRONG, unique values before running
# docker compose. All variables marked [REQUIRED] will cause docker compose
# to fail fast if absent or left as placeholder values.
# ═══════════════════════════════════════════════════════════════════════════

# ── PostgreSQL Per-Service Passwords [REQUIRED] ───────────────────────────
# Use a password manager or: openssl rand -hex 24
POSTGRES_PASSWORD_M01=change-me-m01
POSTGRES_PASSWORD_M02=change-me-m02
POSTGRES_PASSWORD_M03=change-me-m03
POSTGRES_PASSWORD_M04=change-me-m04
POSTGRES_PASSWORD_M05=change-me-m05
POSTGRES_PASSWORD_M06=change-me-m06
POSTGRES_PASSWORD_M07=change-me-m07
POSTGRES_PASSWORD_M08=change-me-m08
POSTGRES_PASSWORD_M09=change-me-m09
POSTGRES_PASSWORD_M10=change-me-m10
POSTGRES_PASSWORD_M11=change-me-m11
POSTGRES_PASSWORD_M12=change-me-m12
POSTGRES_PASSWORD_M13=change-me-m13
POSTGRES_PASSWORD_M14=change-me-m14
POSTGRES_PASSWORD_M15=change-me-m15
POSTGRES_PASSWORD_M16=change-me-m16
POSTGRES_PASSWORD_M17=change-me-m17

# ── MinIO Object Storage [REQUIRED] ──────────────────────────────────────
MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-minio-password-32chars

# ── Grafana [REQUIRED] ────────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-password

# ── CORS & WebSocket Origin Allowlists [REQUIRED] ─────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002
WS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002

# ── Super Admin JWT (M15 Admin Panel) [REQUIRED] ──────────────────────────
ADMIN_JWT_SECRET=change-this-to-a-long-random-secret-in-production

# ── Stripe (M14 Billing) ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ── SMTP / Email Alerts (M04 Alerts) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password

# ── Twilio / SMS Alerts (M04 Alerts) ─────────────────────────────────────
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=+0000000000
